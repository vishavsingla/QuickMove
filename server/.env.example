PORT=5001
# Set to 1 behind Render/nginx (auto-enabled when NODE_ENV=production)
TRUST_PROXY="0"
DATABASE_URL="postgresql://postgres:postgres@localhost:5433/quickmove?schema=public"
DIRECT_URL="postgresql://postgres:postgres@localhost:5433/quickmove?schema=public"
ACCESS_TOKEN_PRIVATE_KEY="change_me_access_secret"
REFRESH_TOKEN_PRIVATE_KEY="change_me_refresh_secret"
ACCESS_TOKEN_TTL="7d"
ADMIN_SIGNUP_SECRET="quickmove-admin"
CLIENT_ORIGIN="http://localhost:3000"
# Optional: comma-separated origins (overrides CLIENT_ORIGIN when set)
# CORS_ORIGINS="http://localhost:3000,https://quickmove.vercel.app,https://*.vercel.app"
# Local: redis://localhost:6379
# Upstash (TLS): rediss://default:<token>@<host>.upstash.io:6379
REDIS_URL="redis://localhost:6379"
NOMINATIM_URL="https://nominatim.openstreetmap.org"
PHOTON_URL="https://photon.komoot.io"
OPEN_METEO_URL="https://geocoding-api.open-meteo.com"
OSRM_URL="https://router.project-osrm.org"
# Razorpay (optional — mock checkout works without keys)
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""
# OTP debug: return code in API response when NODE_ENV!=production OR OTP_DEBUG=true
OTP_DEBUG="false"
# Google OAuth (optional — stub message when unset)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
# Defaults to http://localhost:5001/api/auth/oauth/google/callback
GOOGLE_OAUTH_REDIRECT_URI=""
